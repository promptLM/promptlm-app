{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "jsx": "react-jsx",
    "types": ["react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/index.ts",
    "src/lib/**/*.ts",
    "src/theme/**/*.ts",
    "src/layout/**/*.ts",
    "src/layout/**/*.tsx",
    "src/components/ui/**/*.ts",
    "src/components/ui/**/*.tsx",
    "src/components/InfoCard/**/*.ts",
    "src/components/InfoCard/**/*.tsx",
    "src/components/SectionCard/**/*.ts",
    "src/components/SectionCard/**/*.tsx",
    "src/prompt-editor/**/*.ts",
    "src/prompt-editor/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
