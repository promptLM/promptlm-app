{
  "name": "prompteval",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "components/ui",
    "components/promptlm-api-client",
    "components/promptlm-web-ui",
    "components/promptlm-report-static"
  ],
  "scripts": {
    "contracts:validate:asyncapi": "npm --workspace @promptlm/api-client run validate:asyncapi",
    "contracts:generate": "npm --workspace @promptlm/api-client run generate",
    "contracts:build": "npm --workspace @promptlm/api-client run build",
    "webapp:test": "npm --workspace @promptlm/web-ui run test",
    "webapp:build": "npm --workspace @promptlm/web-ui run build",
    "docs:build": "node scripts/build-docs.mjs"
  },
  "devDependencies": {
    "@asciidoctor/core": "^3.0.4",
    "yaml": "^2.6.1"
  },
  "overrides": {
    "handlebars": "^4.7.9",
    "fast-uri": "^3.1.2",
    "lodash": "^4.18.0",
    "picomatch": "^4.0.4",
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "readdirp": {
      "picomatch": "^2.3.2"
    }
  }
}
